            variableWidth: false,
            arrows: false,
            autoplay: true,
          }
        });
      });

      if ($('.active-slider.resource-slider').length) {
          $('.resource-slider').find('article').each(function() {
            if ($(this).hasClass('fsResourceTypeImage')) {
              var figure = $(this).find('figure');
              var myImg = $(this).find('img');
              myImg.attr('src', getImageSize(myImg));
              backgroundImage($(figure));
            }
          });

          var checkSlider = setInterval(function() {
            var slickSlide = $(".resource-slider .slick-slider.slick-initialized");
            if (slickSlide.length) {
              clearInterval(checkSlider);
              slickSlide.slick('slickSetOption', 'pauseOnHover', false, false);
              slickSlide.slick('slickSetOption', 'pauseOnFocus', false, false);

              slickSlide.on({
                'beforeChange': function(event, slick, currentSlide, nextSlide) {
                  var video = slick.$slides.eq(slick.currentSlide).find('video');
                  if (video.length) {
                    video[0].pause();
                    slick.slickPlay();
                  } else {
                    slick.slickPause();
                  }
                },
                'afterChange': function(event, slick, currentSlide, nextSlide) {
                  var video = slick.$slides.eq(slick.currentSlide).find('video');
                  if (video.length) {
                    video[0].play();
                  } else {
                    slick.slickPlay();
                  }
                }
              });

            }
          }, 100);

