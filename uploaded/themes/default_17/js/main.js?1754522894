    slideshow: function() {

      $('.home').each(function() {

        var sliderArray = $(this).find('.universal-slideshow, .resource-slider').toArray();
        var sliderShow = sliderArray[Math.floor(Math.random() * sliderArray.length)];
        $(sliderShow).addClass('active-slider');
        $('body:not(.fsDraftMode) .resource-slider:not(.active-slider)').remove();

      });

      // src/plugins/fsMediaPull.js
      $('.active-slider:not(.resource-slider)').each(function() {
        var self = $(this);

        self.mediaSlider({
          mediaTemplate: [
            '<article class="universal-slide" style="background-image: url({imgSrc});">',
            '<img src="{imgSrc}" alt="{captionTitle}" class="universal-img" />',
            '<div class="caption-wrapper">',
