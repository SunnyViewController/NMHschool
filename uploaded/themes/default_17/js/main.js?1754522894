      });

      // Remove attribute on the bottom if anything other than
      // what is mentioned is clicked on
      $(document).on('click', function(event) {
        if (!$(event.target).closest('#fsMenu, .drawer-trigger').length) {
          $body.removeClass('drawer-is-active');
        }
      });
    }

  };

  OFFCANVAS.init();

  // ================================
  // Sub Navigation
  // ================================

  SUBNAV = {

    init: function() {

      this.title();
      this.mobileNav();

    },

    // Create a section title based on the current page
    title: function() {
      if (sectionTitle.length !== 0) {
        $navSub_title.html('In This Section');
      }

      if ($navSub.find('nav .fsNavLevel1').length !== 0) {
        $navSub.removeClass('nav-sub-empty');
      } else {
        $navSub.addClass('nav-sub-empty');
      }

    },

    mobileNav: function() {
      // nav-sub - mobile toggle
      $navSub_title.click(function() {
        $(this).closest($navSub).toggleClass('active-nav');
      });

      // nav-sub remove click elsewhere
      $(document).on('click', function(event) {
        if (!$(event.target).closest($navSub).length) {
          $navSub.removeClass('active-nav');
        }
      });

    }

  };

  SUBNAV.init();

  // ================================
  // Utility & milliseconds Functions
  // ================================

  UTIL = {

    init: function() {

      this.respondSliders();
      this.accessibilityMenu();
      this.googleTranslateAccessibility();
      this.imageModule();
      this.calendarWrapper();
      this.newsArticles();
      this.calloutLink();
      this.mainMenu();
      if($('body:not(.publications-2):not(.publications-2022)').length) {
        this.fixedNav();
      }
      this.quicklinks();
      this.announcement();
      this.miscellaniousFunctions();
      this.imageFlaot();
      this.profileRandomizer();

    },

    respondSliders: function() {

      // ================================
      // Responsive Built-in sliders
      // ================================

      // the following takes care of the news/calendar slideshow option
      // and makes them responsive

      var targets = [
        // '.fsPostElement.fsSlideshow',
        '.fsCalendar.fsSlideshow'
      ];

      var bp = [{
        breakpoint: bpLandscape,
        settings: {
          slidesToShow: 4,
        }
      }, {
        breakpoint: bpTablet,
        settings: {
          slidesToShow: 3,
          slidesToScroll: 1,
          infinite: true,
        }
      }, {
        breakpoint: 750,
        settings: {
          slidesToShow: 2,
        }
      }, {
        breakpoint: bpMobile,
        settings: {
          slidesToShow: 1,
          slidesToScroll: 1,
          dots: false
        }
      }];

      for (var i = 0; i < targets.length; i++) {
        $(targets[i] + ' .fsElementSlideshow')
          .slick('slickSetOption', 'responsive', bp, true);
      }
    },

    accessibilityMenu: function() {

      if (notDraftMode) {

        $navMain.find('.fsNavLevel1').columns({
          columns: 2
        });

        $navMain.find(".fsNavLevel1").accessibility_menu();


        // $('.nav-hub').find('.fsNavLevel1').accessibility_menu();
      }
    },

    googleTranslateAccessibility: function() {

      var checkTranslate = setInterval(function() {
        if ($("#google_translate_element select.goog-te-combo").length) {
          clearInterval(checkTranslate);
          if ((!$("#google_translate_element select.goog-te-combo").parent()[0].length && $("#google_translate_element select.goog-te-combo").parent()[0].tagName !== "LABEL") && (!$("#google_translate_element select.goog-te-combo").prev().length || $("#google_translate_element select.goog-te-combo").prev()[0].tagName !== "LABEL")) {
            $("#google_translate_element select.goog-te-combo").before('<label for="select-translate">Translate Website</label>');
            $("#google_translate_element select.goog-te-combo").attr("id", "select-translate");
          }
        }
      }, 200);

    },

    imageModule: function() {

      $('.img-module').each(function() {
        $(this).find('img').prependTo(this);
      });
    },

    calendarWrapper: function() {

      if ($('.fsCalendarTools').length) {
        $(document).ajaxComplete(function() {
          $('.fsCalendar.fsList article').each(function() {
            $(this).wrapInner('<div class="article-wrapper"></div>');
          });
        });
      }

      $('.fsCalendar.fsList article').each(function() {
        $(this).wrapInner('<div class="article-wrapper"></div>');
      });

    },

    newsArticles: function() {

      $('.fsNews article > .fsDateTime').each(function() {
        $(this).prepend('<span class="date-label">Posted: </div>');
      });
      $('.fsNews article').each(function() {
        var dateTime = $(this).find('.fsDateTime');

        dateTime.insertAfter($(this).find('.fsThumbnail'));

      });
      $('.fsNews article > .fsSummary').dotdotdot({
        watch: 'window'
      });
    },

    calloutLink: function() {

      $('.callout-top').each(function() {
        var link = $(this).find('.fsElementFooterContent > div > a').attr('href');
        var name = $(this).find('.fsElementFooterContent > div > a').attr('data-page-name');

        $(this).wrap('<a href="' + link + '" data-page-name="' + name + '" class="callout-wrapper" target="_blank"></a>');
      });
    },

    mainMenu: function() {

      if ($('.athletics').length) {
        $navMain.find('.column-1 > li:not(:first-of-type)').find('.fsNavLevel2').columns({
          columns: 2
        });
        $navMain.find('.column-2').find('.fsNavLevel2').columns({
          columns: 2
        });

        $navMain.find('.fsNavLevel1 > li').each(function() {
          if ($(this).find('.fsNavLevel2.column-2').length) {
            return true;
          } else {
            $(this).find('.fsNavLevel2.column-1').addClass('single-column');
          }
        });

        $navMain.find('.column-1 > li:not(:first-of-type) .fsNavPageInfo').each(function() {
          $(this).children().not('.fsNavLevel2').wrapAll("<div class='menu-wrapper'></div>");
        });
        $navMain.find('.column-2 > li .fsNavPageInfo').each(function() {
          $(this).children().not('.fsNavLevel2').wrapAll("<div class='menu-wrapper'></div>");
        });
      }

      if (!$('.athletics').length) {
        $navMain.find('.fsNavLevel2').columns({
          columns: 2
        });

        $navMain.find('.fsNavPageInfo').each(function() {
          $(this).children().not('.fsNavLevel2').wrapAll("<div class='menu-wrapper'></div>");
        });
      }

    },

    fixedNav: function() {

      var $menuStick = $('.nav-main').offset().top;

      $navMain.prepend('<span class="fixed-logo"><a href="/"></a></span');

      function fixedHeader() {
        if ($(window).width() > 999) {
          if ($(window).scrollTop() >= $menuStick) {
            $navMain.addClass('is-fixed');
            $('.site-info-container').addClass('is-fixed');
            if ($('#fsAccountBar').length) {
              $navMain.addClass('fixed-account');
            } else {
              $navMain.removeClass('fixed-account');
            }
          } else {
            $navMain.removeClass('is-fixed');
            $('.site-info-container').removeClass('is-fixed');

          }
        } else {
          $navMain.removeClass('is-fixed');
          $('.site-info-container').removeClass('is-fixed');
        }
      }

      $(window).on('load resize', function() {
        if ($('body:not(.fsComposeMode)').length) {
          var scroll = false;

          $(window).scroll(function() {
            scroll = true;
          });

          setInterval(function() {
            if (scroll) {
              scroll = false;

              fixedHeader();

            }
          }, 100);
        }
      });
    },

    miscellaniousFunctions: function() {

      //SmoothScrolling
      $('.universal-slideshow footer a.smoothScroll, .resource-slider  footer a.smoothScroll').smoothScroll({
        offset: -100
      });

      //Double Tap
      $navMain.find(".fsNavLevel1 > li ").doubleTapToGo();

      //Interior Hero
      if (notComposeMode && $('.interior-hero').length) {
        if($('.interior-hero.fsResourceElement').length) {
          var myImg = $('.interior-hero.fsResourceElement img');
          myImg.attr('src', getImageSize(myImg));
        }
        $('.interior-hero').appendTo('.fsHeader > .fsBanner');
      }

      //Breadcrumb Nav
      $('.fsBreadcrumb').prependTo('.fsPageBodyWrapper');

      //Feeds in Tabs
      if (notComposeMode) {
        FS.events.onElementShown('athletics-feeds panel', function($element) {
          // console.log("lol");
          Juicer.initialize();
        });
      }

      //Fixed background fix for iOS
      var iOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

      if (iOS) {
        $('.footer-image').addClass('ios-fix');
      }
    },

    quicklinks: function() {

      $(window).on('load', function() {
        $('.quicklinks').each(function() {
          var linksWidth = -($(this).css('width').replace(/[^-\d\.]/g, ''));

          $(this).css('left', linksWidth);
        });
      });



      $('.quicklinks > header').on('click', function() {
        $(this).parent().toggleClass('active');
      });
    },

    announcement: function() {

      if ($('.announcement').length && !$('.announcement').hasClass('hidden')) {
        $('.announcement').before('<div class="announcement-tag">Announcement Open</div');
      }

      $('.announcement .close-btn').on('click', function() {
        $('.announcement, .announcement-tag').addClass('hide-announcement');
      });
      $('.announcement-tag').on('click', function() {
        $('.announcement, .announcement-tag').removeClass('hide-announcement');
      });

      $(window).on('load resize', function() {
        if ($(window).width() < 999) {
          $('.announcement, .announcement-tag').addClass('hide-announcement');
        }
      });

      if ($('.announcement').length && $('.announcement').hasClass('begin-closed')) {
        $('.announcement, .announcement-tag').addClass('hide-announcement');

      }

      /*if (isHome) {
        $('.announcement, .announcement-tag').addClass('hide-announcement');
      }*/


    },

    imageFlaot: function() {

      var imgFloat = $('img[style*="float"]');

      if (imgFloat.length) {
        imgFloat.each(function() {
          $(this).parent().addClass('image-clear');
          // ("<div class='image-clear'></div>");
        });
      }
    },

    profileRandomizer: function() {

      $('.profile').each(function() {

        var profileArray = $(this).find('.fsListItems').children().toArray();
        var profileShow = profileArray[Math.floor(Math.random() * profileArray.length)];

        $(profileShow).addClass('show-profile');

        $(this).find('article').each(function() {
          $(this).children().not(':first-child').wrapAll("<div class='text-wrapper'></div>");
        });
      });

    }

  };

  if (isDirectory) {
    setTimeout(function() {
      $('.fsConstituentItem').each(function() {
        var title = $(this).find('.fsJobTitle');
        title.insertAfter($(this).find('.fsDepartments'));
      });
    }, 200);
  }

  UTIL.init();

